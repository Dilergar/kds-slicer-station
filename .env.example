# KDS Slicer Station Environment Configuration
# Скопируйте этот файл в .env.local и подставьте свои значения

# -----------------
# 🗄️ База Данных (PostgreSQL) - Для будущего шага интеграции
# -----------------

# Строка подключения для прямого запроса из NodeJS/Prisma (если используется бекенд)
# VITE_DATABASE_URL="postgresql://postgres:password@localhost:5432/kds_db"

# -----------------
# 🚀 Приложение (Frontend Settings)
# -----------------

# Порт, на котором запустится Vite сервер (по умолчанию 5173)
# PORT=5173

# Тема по умолчанию (dark/light)
VITE_THEME="dark"

# Язык по умолчанию (en / ru)
VITE_DEFAULT_LANG="en"
