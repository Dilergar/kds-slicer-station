# Пример конфигурации backend модуля KDS Slicer Station.
# Скопируйте этот файл в server/.env и заполните реальными значениями.
# Файл server/.env в git не коммитится (см. .gitignore).

# --- Подключение к PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=arclient
DB_USER=postgres
DB_PASSWORD=your_password_here

# --- Express сервер ---
# Frontend проксирует /api → localhost:3001 (см. vite.config.ts),
# поэтому менять порт не рекомендуется.
SERVER_PORT=3001
